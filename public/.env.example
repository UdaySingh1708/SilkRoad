# ==========================================
# Silk Road - Environment Configuration
# ==========================================

# Server
PORT=3000
NODE_ENV=development

# CORS
CLIENT_URL=http://localhost:3000

# Security
SESSION_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_KEY

# Chat
MAX_MESSAGE_LENGTH=500
MESSAGE_RATE_LIMIT=5
MATCH_TIMEOUT=60

# Socket.IO
PING_TIMEOUT=20000
PING_INTERVAL=25000